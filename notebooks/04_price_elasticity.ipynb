# %% [markdown]
# # 04 — Price Elasticity Analysis
# Estimate price elasticity of demand at overall, category, and product levels.

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import sys
from pathlib import Path

ROOT = Path(".").resolve().parent
sys.path.insert(0, str(ROOT))

from src.data_pipeline.ingestion import DataIngestion
from src.models.elasticity_model import ElasticityModel

# %%
ingestion = DataIngestion()
sales = ingestion.load_sales()
catalog = ingestion.load_catalog()
merged = sales.merge(catalog[["product_id", "base_price", "cost"]], on="product_id", how="left")

# %% [markdown]
# ## Overall Elasticity

# %%
model = ElasticityModel(alpha=1.0)
overall = model.estimate_overall(merged)
print(f"Overall Price Elasticity: {overall['elasticity']:.4f}")
print(f"R²: {overall['r2']:.4f}")
print(f"Observations: {overall['n_obs']:,}")

# %% [markdown]
# ## Category-Level Elasticity

# %%
cat_elast = model.estimate_by_category(merged)
cat_df = pd.DataFrame([
    {"category": k, "elasticity": v["elasticity"], "r2": v["r2"], "n_obs": v["n_obs"]}
    for k, v in cat_elast.items()
]).sort_values("elasticity")

fig, ax = plt.subplots(figsize=(10, 6))
colors = ["tomato" if e < -1 else "steelblue" for e in cat_df["elasticity"]]
ax.barh(cat_df["category"], cat_df["elasticity"], color=colors, edgecolor="white")
ax.axvline(x=-1, color="gray", linestyle="--", alpha=0.5, label="Unit Elastic (-1)")
ax.set_xlabel("Price Elasticity")
ax.set_title("Price Elasticity by Category")
ax.legend()
plt.tight_layout()
plt.show()

print(cat_df.to_string(index=False))

# %% [markdown]
# ## Product-Level Elasticity

# %%
prod_elast = model.estimate_by_product(merged, min_observations=60)
print(f"Products with elasticity estimates: {len(prod_elast)}")

elast_values = [v["elasticity"] for v in prod_elast.values() if not np.isnan(v["elasticity"])]
plt.figure(figsize=(10, 5))
plt.hist(elast_values, bins=50, edgecolor="white", alpha=0.7, color="teal")
plt.axvline(x=-1, color="red", linestyle="--", label="Unit Elastic")
plt.axvline(x=np.median(elast_values), color="orange", linestyle="--", label=f"Median ({np.median(elast_values):.2f})")
plt.xlabel("Price Elasticity")
plt.ylabel("Number of Products")
plt.title("Distribution of Product-Level Price Elasticities")
plt.legend()
plt.show()

# %% [markdown]
# ## Demand Curves

# %%
# Show demand curves for one product per category
fig, axes = plt.subplots(2, 4, figsize=(20, 10))
for ax, cat in zip(axes.flat, sorted(merged["category"].unique())):
    cat_data = merged[merged["category"] == cat]
    sample_product = cat_data["product_id"].value_counts().index[0]
    prod_data = cat_data[cat_data["product_id"] == sample_product]
    prod_data = prod_data[(prod_data["price"] > 0) & (prod_data["units_sold"] > 0)]

    ax.scatter(prod_data["price"], prod_data["units_sold"], alpha=0.3, s=10, color="steelblue")
    ax.set_title(f"{cat}\n({sample_product})", fontsize=9)
    ax.set_xlabel("Price")
    ax.set_ylabel("Units")

plt.suptitle("Price-Demand Scatter by Category (sample products)", fontsize=14)
plt.tight_layout()
plt.show()
