# %% [markdown]
# # 03 — Demand Forecasting
# Train and evaluate gradient boosted demand forecasting models.

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import sys
from pathlib import Path

ROOT = Path(".").resolve().parent
sys.path.insert(0, str(ROOT))

from src.data_pipeline.ingestion import DataIngestion
from src.data_pipeline.cleaning import DataCleaner
from src.data_pipeline.transformation import DataTransformer
from src.features.build_features import FeatureBuilder
from src.models.demand_forecast import DemandForecaster
from src.models.model_utils import temporal_train_test_split, prepare_features
from src.evaluation.metrics import regression_metrics, demand_forecast_by_segment

# %%
# Load and prepare data
ingestion = DataIngestion()
data = ingestion.load_all()
cleaner = DataCleaner()
data["sales"] = cleaner.clean_sales(data["sales"])
data["catalog"] = cleaner.clean_catalog(data["catalog"])
data["competitors"] = cleaner.clean_competitors(data["competitors"])
data["inventory"] = cleaner.clean_inventory(data["inventory"])

transformer = DataTransformer()
master = transformer.build_master_dataset(data)

feature_builder = FeatureBuilder()
features = feature_builder.build_all_features(master)

# %%
train, test = temporal_train_test_split(features)
feature_cols = [c for c in DemandForecaster.FEATURE_COLS if c in features.columns]
print(f"Using {len(feature_cols)} features")

X_train, y_train = prepare_features(train, feature_cols, "units_sold")
X_test, y_test = prepare_features(test, feature_cols, "units_sold")
print(f"Train: {X_train.shape}, Test: {X_test.shape}")

# %% [markdown]
# ## Model Training

# %%
forecaster = DemandForecaster(model_type="gbr")
forecaster.train(X_train, y_train)

# %%
# Feature importance
if forecaster.feature_importance is not None:
    top20 = forecaster.feature_importance.head(20)
    plt.figure(figsize=(10, 8))
    plt.barh(range(len(top20)), top20["importance"], color="steelblue")
    plt.yticks(range(len(top20)), top20["feature"])
    plt.title("Top 20 Feature Importances")
    plt.xlabel("Importance")
    plt.gca().invert_yaxis()
    plt.tight_layout()
    plt.show()

# %% [markdown]
# ## Evaluation

# %%
metrics = forecaster.evaluate(X_test, y_test)
print("\nTest Set Metrics:")
for k, v in metrics.items():
    print(f"  {k}: {v}")

# %%
preds = forecaster.predict(X_test)

# Actual vs Predicted scatter
fig, axes = plt.subplots(1, 2, figsize=(14, 6))
axes[0].scatter(y_test, preds, alpha=0.1, s=5)
max_val = max(y_test.max(), preds.max())
axes[0].plot([0, max_val], [0, max_val], "r--", alpha=0.5)
axes[0].set_xlabel("Actual")
axes[0].set_ylabel("Predicted")
axes[0].set_title("Actual vs Predicted Demand")

errors = y_test.values - preds
axes[1].hist(errors, bins=100, edgecolor="white", alpha=0.7)
axes[1].axvline(x=0, color="red", linestyle="--")
axes[1].set_title("Prediction Error Distribution")
axes[1].set_xlabel("Error (Actual - Predicted)")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Performance by Category

# %%
by_cat = demand_forecast_by_segment(y_test, preds, test.loc[y_test.index, "category"])
print(by_cat[["mae", "rmse", "mape", "r2", "n_samples"]])
