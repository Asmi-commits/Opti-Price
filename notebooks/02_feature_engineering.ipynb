# %% [markdown]
# # 02 — Feature Engineering
# Build and validate the full feature set for demand forecasting and pricing models.

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import sys
from pathlib import Path

ROOT = Path(".").resolve().parent
sys.path.insert(0, str(ROOT))

from src.data_pipeline.ingestion import DataIngestion
from src.data_pipeline.cleaning import DataCleaner
from src.data_pipeline.transformation import DataTransformer
from src.features.build_features import FeatureBuilder

# %%
ingestion = DataIngestion()
data = ingestion.load_all()

cleaner = DataCleaner()
data["sales"] = cleaner.clean_sales(data["sales"])
data["catalog"] = cleaner.clean_catalog(data["catalog"])
data["competitors"] = cleaner.clean_competitors(data["competitors"])
data["inventory"] = cleaner.clean_inventory(data["inventory"])

transformer = DataTransformer()
master = transformer.build_master_dataset(data)

# %%
feature_builder = FeatureBuilder()
features = feature_builder.build_all_features(master)
print(f"Feature matrix: {features.shape}")
print(f"\nFeature columns ({len(feature_builder.get_feature_names())}):")
for f in sorted(feature_builder.get_feature_names()):
    print(f"  {f}: {features[f].dtype}")

# %% [markdown]
# ## Feature Distributions

# %%
key_features = [
    "price_to_base_ratio", "demand_rolling_mean_7d", "price_volatility_7d",
    "supply_risk_score", "price_vs_competition", "demand_velocity_7d",
]
fig, axes = plt.subplots(2, 3, figsize=(16, 10))
for ax, feat in zip(axes.flat, key_features):
    if feat in features.columns:
        features[feat].dropna().hist(bins=50, ax=ax, edgecolor="white", alpha=0.7)
        ax.set_title(feat)
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Feature Correlations with Target

# %%
numeric_feats = feature_builder.get_numeric_features(features)
target = "units_sold"
correlations = features[numeric_feats + [target]].corr()[target].drop(target).sort_values()
top_pos = correlations.tail(15)
top_neg = correlations.head(15)

fig, axes = plt.subplots(1, 2, figsize=(16, 8))
top_pos.plot.barh(ax=axes[0], color="seagreen")
axes[0].set_title("Top Positive Correlations with Demand")
top_neg.plot.barh(ax=axes[1], color="tomato")
axes[1].set_title("Top Negative Correlations with Demand")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Missing Value Analysis

# %%
missing = features.isnull().sum()
missing_pct = (missing / len(features) * 100).round(1)
missing_report = pd.DataFrame({"count": missing, "pct": missing_pct})
missing_report = missing_report[missing_report["count"] > 0].sort_values("pct", ascending=False)
print(f"Columns with missing values: {len(missing_report)}")
print(missing_report.head(20))
