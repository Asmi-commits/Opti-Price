# %% [markdown]
# # 05 — Pricing Simulation
# Simulate revenue/profit impact of different pricing strategies.

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import sys
from pathlib import Path

ROOT = Path(".").resolve().parent
sys.path.insert(0, str(ROOT))

from src.data_pipeline.ingestion import DataIngestion
from src.models.elasticity_model import ElasticityModel
from src.models.pricing_optimizer import PricingOptimizer, PricingConstraints
from src.evaluation.revenue_simulation import RevenueSimulator

# %%
ingestion = DataIngestion()
sales = ingestion.load_sales()
catalog = ingestion.load_catalog()

# Fit elasticity model
elast_model = ElasticityModel()
elast_model.estimate_by_category(sales)
elast_model.estimate_by_product(sales, min_observations=60)

# %% [markdown]
# ## Single Product Simulation

# %%
simulator = RevenueSimulator(elast_model)
sample_product = catalog.iloc[0]

sim_results = simulator.simulate_price_change(
    product_id=sample_product["product_id"],
    current_price=sample_product["base_price"],
    current_demand=50,
    cost=sample_product["cost"],
    price_changes=np.arange(-0.25, 0.26, 0.01).tolist(),
    category=sample_product["category"],
)

fig, axes = plt.subplots(1, 3, figsize=(18, 5))
axes[0].plot(sim_results["price_change_pct"], sim_results["predicted_demand"], color="steelblue", linewidth=2)
axes[0].axvline(x=0, color="gray", linestyle="--", alpha=0.3)
axes[0].set_title("Demand Curve")
axes[0].set_xlabel("Price Change (%)")
axes[0].set_ylabel("Predicted Demand")

axes[1].plot(sim_results["price_change_pct"], sim_results["revenue"], color="seagreen", linewidth=2)
axes[1].axvline(x=0, color="gray", linestyle="--", alpha=0.3)
max_rev_idx = sim_results["revenue"].idxmax()
axes[1].axvline(x=sim_results.loc[max_rev_idx, "price_change_pct"], color="red", linestyle="--", alpha=0.5)
axes[1].set_title("Revenue Curve")
axes[1].set_xlabel("Price Change (%)")
axes[1].set_ylabel("Revenue ($)")

axes[2].plot(sim_results["price_change_pct"], sim_results["profit"], color="coral", linewidth=2)
axes[2].axvline(x=0, color="gray", linestyle="--", alpha=0.3)
max_prof_idx = sim_results["profit"].idxmax()
axes[2].axvline(x=sim_results.loc[max_prof_idx, "price_change_pct"], color="red", linestyle="--", alpha=0.5)
axes[2].set_title("Profit Curve")
axes[2].set_xlabel("Price Change (%)")
axes[2].set_ylabel("Profit ($)")

plt.suptitle(f"Price Sensitivity: {sample_product['product_id']} ({sample_product['category']})")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Portfolio Optimization

# %%
# Build portfolio from recent data
latest = sales.groupby("product_id").last().reset_index()
portfolio = latest[["product_id", "category", "price", "units_sold"]].rename(
    columns={"price": "current_price", "units_sold": "current_demand"}
)
portfolio = portfolio.merge(catalog[["product_id", "cost"]], on="product_id", how="left")

optimizer = PricingOptimizer(elast_model, objective="profit")
recommendations = optimizer.optimize_portfolio(portfolio)

# %%
fig, axes = plt.subplots(1, 2, figsize=(16, 6))
axes[0].hist(recommendations["price_change_pct"], bins=40, edgecolor="white", color="teal", alpha=0.7)
axes[0].axvline(x=0, color="red", linestyle="--")
axes[0].set_title("Distribution of Recommended Price Changes")
axes[0].set_xlabel("Price Change (%)")

axes[1].hist(recommendations["profit_uplift_pct"], bins=40, edgecolor="white", color="coral", alpha=0.7)
axes[1].axvline(x=0, color="red", linestyle="--")
axes[1].set_title("Distribution of Expected Profit Uplift")
axes[1].set_xlabel("Profit Uplift (%)")
plt.tight_layout()
plt.show()

# %%
print(f"\nPortfolio Summary:")
print(f"  Products: {len(recommendations)}")
print(f"  Avg price change: {recommendations['price_change_pct'].mean():.1f}%")
print(f"  Total current revenue: ${recommendations['current_revenue'].sum():,.0f}")
print(f"  Total expected revenue: ${recommendations['expected_revenue'].sum():,.0f}")
print(f"  Revenue uplift: ${recommendations['expected_revenue'].sum() - recommendations['current_revenue'].sum():,.0f}")
print(f"  Profit uplift: ${recommendations['expected_profit'].sum() - recommendations['current_profit'].sum():,.0f}")

# %% [markdown]
# ## Scenario Comparison

# %%
scenarios = {
    "Status Quo": lambda row: row["current_price"],
    "5% Across-the-Board Increase": lambda row: row["current_price"] * 1.05,
    "5% Across-the-Board Decrease": lambda row: row["current_price"] * 0.95,
    "Premium +10%, Budget -5%": lambda row: (
        row["current_price"] * 1.10 if row.get("category") in ["Electronics", "Beauty"]
        else row["current_price"] * 0.95
    ),
}

comparison = simulator.compare_scenarios(portfolio, scenarios)
print(comparison.to_string(index=False))
