# %% [markdown]
# # 01 — Data Exploration
# Explore the raw datasets: distributions, missing values, relationships.

# %%
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import sys
from pathlib import Path

ROOT = Path(".").resolve().parent
sys.path.insert(0, str(ROOT))

from src.data_pipeline.ingestion import DataIngestion

plt.rcParams.update({"figure.figsize": (12, 5), "figure.dpi": 110})

# %%
ingestion = DataIngestion()
sales = ingestion.load_sales()
catalog = ingestion.load_catalog()
competitors = ingestion.load_competitors()
inventory = ingestion.load_inventory()
holidays = ingestion.load_holidays()

# %% [markdown]
# ## Sales Data Overview

# %%
print(f"Shape: {sales.shape}")
print(f"Date range: {sales['date'].min()} → {sales['date'].max()}")
print(f"Products: {sales['product_id'].nunique()}")
print(f"Categories: {sales['category'].nunique()}")
print(f"\nColumn types:\n{sales.dtypes}")
print(f"\nMissing values:\n{sales.isnull().sum()}")

# %%
sales.describe()

# %% [markdown]
# ## Revenue Distribution

# %%
fig, axes = plt.subplots(1, 3, figsize=(18, 5))
axes[0].hist(sales["price"], bins=100, edgecolor="white", alpha=0.7)
axes[0].set_title("Price Distribution")
axes[0].set_xlabel("Price ($)")

axes[1].hist(sales["units_sold"], bins=100, edgecolor="white", alpha=0.7)
axes[1].set_title("Units Sold Distribution")
axes[1].set_xlabel("Units")

axes[2].hist(np.log1p(sales["revenue"]), bins=100, edgecolor="white", alpha=0.7)
axes[2].set_title("Log Revenue Distribution")
axes[2].set_xlabel("ln(Revenue + 1)")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Category Analysis

# %%
cat_stats = sales.groupby("category").agg(
    total_revenue=("revenue", "sum"),
    avg_price=("price", "mean"),
    avg_units=("units_sold", "mean"),
    num_products=("product_id", "nunique"),
    promo_rate=("is_promotion", "mean"),
).sort_values("total_revenue", ascending=False)
cat_stats

# %%
fig, axes = plt.subplots(1, 2, figsize=(16, 6))
cat_stats["total_revenue"].plot.barh(ax=axes[0], color="steelblue")
axes[0].set_title("Revenue by Category")
axes[0].set_xlabel("Total Revenue ($)")

cat_stats["avg_price"].plot.barh(ax=axes[1], color="coral")
axes[1].set_title("Average Price by Category")
axes[1].set_xlabel("Avg Price ($)")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Time Series Patterns

# %%
daily = sales.groupby("date").agg(revenue=("revenue", "sum"), units=("units_sold", "sum"))
fig, ax = plt.subplots(figsize=(16, 5))
ax.plot(daily.index, daily["revenue"], alpha=0.5, linewidth=0.5)
ax.plot(daily.index, daily["revenue"].rolling(30).mean(), color="red", linewidth=2, label="30-day MA")
ax.legend()
ax.set_title("Daily Revenue with 30-day Moving Average")
plt.show()

# %%
# Day-of-week patterns
dow = sales.groupby("day_of_week")["units_sold"].mean()
dow = dow.reindex(["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"])
dow.plot.bar(color="teal", edgecolor="white")
plt.title("Average Units Sold by Day of Week")
plt.ylabel("Avg Units")
plt.xticks(rotation=45)
plt.show()

# %% [markdown]
# ## Product Catalog

# %%
print(f"Products: {len(catalog)}")
print(f"\nBrand tiers:\n{catalog['brand_tier'].value_counts()}")
print(f"\nCategories:\n{catalog['category'].value_counts()}")

# %%
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
axes[0].scatter(catalog["base_price"], catalog["cost"], alpha=0.6, c="steelblue")
axes[0].plot([0, 2000], [0, 2000], "r--", alpha=0.3)
axes[0].set_xlabel("Base Price")
axes[0].set_ylabel("Cost")
axes[0].set_title("Price vs Cost")

catalog["margin_pct"] = (catalog["base_price"] - catalog["cost"]) / catalog["base_price"]
axes[1].hist(catalog["margin_pct"], bins=30, edgecolor="white", color="seagreen")
axes[1].set_title("Margin Distribution")
axes[1].set_xlabel("Margin %")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Competitor Pricing

# %%
print(f"Competitor records: {len(competitors):,}")
print(f"\nCompetitors:\n{competitors['competitor'].value_counts()}")
comp_summary = competitors.groupby("competitor").agg(
    avg_price=("competitor_price", "mean"),
    avg_diff=("price_difference", "mean"),
    in_stock_rate=("in_stock", "mean"),
)
comp_summary

# %% [markdown]
# ## Correlation Analysis

# %%
numeric_cols = ["price", "units_sold", "revenue", "profit", "promotion_discount_pct"]
corr = sales[numeric_cols].corr()
sns.heatmap(corr, annot=True, fmt=".2f", cmap="RdBu_r", center=0)
plt.title("Correlation Matrix")
plt.tight_layout()
plt.show()
