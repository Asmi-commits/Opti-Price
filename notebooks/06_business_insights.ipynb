# %% [markdown]
# ## Revenue Trends Deep Dive

# %%
monthly = sales.set_index("date").resample("ME").agg(
    revenue=("revenue", "sum"),
    profit=("profit", "sum"),
    units=("units_sold", "sum"),
    avg_price=("price", "mean"),
)

fig, axes = plt.subplots(2, 2, figsize=(16, 10))
monthly["revenue"].plot(ax=axes[0,0], color="steelblue", linewidth=2)
axes[0,0].set_title("Monthly Revenue")
axes[0,0].set_ylabel("$")

monthly["profit"].plot(ax=axes[0,1], color="seagreen", linewidth=2)
axes[0,1].set_title("Monthly Profit")
axes[0,1].set_ylabel("$")

(monthly["profit"] / monthly["revenue"] * 100).plot(ax=axes[1,0], color="coral", linewidth=2)
axes[1,0].set_title("Monthly Margin %")
axes[1,0].set_ylabel("%")

monthly["avg_price"].plot(ax=axes[1,1], color="purple", linewidth=2)
axes[1,1].set_title("Average Price Trend")
axes[1,1].set_ylabel("$")

plt.tight_layout()
plt.show()

# %% [markdown]
# ## Category Performance Matrix

# %%
cat_perf = sales.groupby("category").agg(
    revenue=("revenue", "sum"),
    profit=("profit", "sum"),
    units=("units_sold", "sum"),
    avg_price=("price", "mean"),
    promo_rate=("is_promotion", "mean"),
)
cat_perf["margin_pct"] = (cat_perf["profit"] / cat_perf["revenue"] * 100).round(1)
cat_perf["revenue_share"] = (cat_perf["revenue"] / cat_perf["revenue"].sum() * 100).round(1)
cat_perf = cat_perf.sort_values("revenue", ascending=False)
print(cat_perf.to_string())

# %%
fig, ax = plt.subplots(figsize=(10, 8))
scatter = ax.scatter(
    cat_perf["revenue_share"], cat_perf["margin_pct"],
    s=cat_perf["units"] / 1000, alpha=0.7, c=range(len(cat_perf)), cmap="Set2"
)
for idx, row in cat_perf.iterrows():
    ax.annotate(idx, (row["revenue_share"], row["margin_pct"]),
                fontsize=9, ha="center", va="bottom")
ax.set_xlabel("Revenue Share (%)")
ax.set_ylabel("Margin (%)")
ax.set_title("Category Performance Matrix\n(bubble size = units sold)")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Promotion Effectiveness

# %%
promo_lift = sales.groupby(["category", "is_promotion"])["units_sold"].mean().unstack()
promo_lift.columns = ["No Promo", "With Promo"]
promo_lift["Lift %"] = ((promo_lift["With Promo"] - promo_lift["No Promo"]) / promo_lift["No Promo"] * 100).round(1)
print(promo_lift.sort_values("Lift %", ascending=False).to_string())
