# %% [markdown]
# ## Automated Insights

# %%
generator = InsightsGenerator()
insights = generator.generate_all(sales, catalog)

for insight in insights:
    icon = {"positive": "✅", "negative": "🔴", "neutral": "ℹ️", "mixed": "⚠️", "actionable": "🎯"}.get(insight["impact"], "•")
